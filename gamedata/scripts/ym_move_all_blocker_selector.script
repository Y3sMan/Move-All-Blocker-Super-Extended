--#region Item Blocking

---Return a table merged from blocked_items and cfg_blocked_items
---@return table
function get_all_blocked_items()
    local new_blocked_items = merge_tables({cfg_blocked_items, blocked_items}) or blocked_items
    return new_blocked_items
end

---Return just in-game blocked_items
---@return table
function get_blocked_items()
    return blocked_items
end

---Completely overwrite blocked_items, if you want
---@param new_blocked table
function set_blocked_items(new_blocked)
    blocked_items = new_blocked or blocked_items
end

---Checks if item is in any blocked lists
---@param sec string: Section of the item
---@return boolean
function is_blocked(sec)
    local blocked = get_all_blocked_items()
    return blocked[sec] and true or false
end


--#endregion

--#region Inventory Key Management

local KEY_PRESSED = ui_events.WINDOW_KEY_PRESSED
local KEY_RELEASED = ui_events.WINDOW_KEY_RELEASED

local _inv = ui_inventory.UIInventory.OnKeyboard
function ui_inventory.UIInventory:OnKeyboard(dik, keyboard_action)
	if keyboard_action == KEY_PRESSED then
        if (dik == KEYBIND) then
            KEY_HELD = true
        elseif (dik == TOGGLE_KEYBIND) then
            if KEY_HELD then 
                TOGGLE_HIDE = not TOGGLE_HIDE
            end
        end
	elseif keyboard_action == KEY_RELEASED then
        if (dik == KEYBIND) then
            KEY_HELD = false 
        end
    end
	return _inv(self, dik, keyboard_action)
end

--#endregion

--#region Ammo Blocking
-- pulled from Haruka's Auto Favorites mod
-- love that mod

local slots = {
    [1] = true,
    [2] = true,
    [3] = true,
    [5] = true
}

local get_ammo = utils_item.get_ammo -- (section, id, by_key)

---Gets all ammos for all currently equipped ammos
---@return table[String]: table of sections
function get_all_ammos()
    local g_pairs = pairs
    local ammos = {}

    for slot, _ in g_pairs(slots) do
        local wpn = db.actor:item_in_slot(slot)
        if wpn and not (IsItem("fake_ammo_wpn",wpn:section())) then
            local sec = wpn:section()
            local ammo_list = get_ammo(nil, wpn:id(), true)
            for ammo, _ in g_pairs(ammo_list) do
                ammos[ammo] = true
            end
        end
    end

    return ammos
end

function block_equipped_ammos()
    debug("equipped_ammos:")
    print_table(equipped_ammos)

    local diffs = {}
    local ammos = get_all_ammos() or {}
    debug("size of equipped_ammos = %s", size_table(equipped_ammos))
    if (size_table(equipped_ammos) > 0) then

        debug("all ammos rn:")
        print_table(ammos)

        for ammo, _ in pairs(equipped_ammos) do
            if not ammos[ammo] then
                diffs[ammo] = true
                -- unblock no longer equipped ammos
                set_blocked(ammo, false)
            end
        end

        -- clear cache
        empty_table(equipped_ammos)
    end


    if not BLOCK_AMMO then return end

    debug("diffs:")
    print_table(diffs)

    -- update cache to all currently equipped ammos
    copy_table(equipped_ammos, ammos)
    -- 

    -- block new ammos
    for ammo, _ in pairs(equipped_ammos) do
        set_blocked(ammo, true)
    end

    -- debug("ammos to remove:")
    -- print_table(diffs)

    debug("equipped_ammos after:")
    print_table(equipped_ammos)
end

--#endregion


--#region context menu function

---Toggle the blocked status of an item
---@param sec string: The section of the item 
---@param state boolean: Whether to block(true) or unblock(false) an item
function set_blocked(sec, state)
    if state then
        if not cfg_blocked_items[sec] then
            blocked_items[sec] = "blocked"
        end
    else
        if blocked_items[sec] then
            blocked_items[sec] = nil
        elseif cfg_blocked_items[sec] then
            cfg_blocked_items[sec] = nil
        end
    end
end



--[[
   name_condition_function: function, the condition at which you will get your right-click option for item
--]]
function can_be_blocked(itm)
    debug("key_held = %s", KEY_HELD)
    debug("toggle = %s", TOGGLE_HIDE)

    return (not TOGGLE_HIDE) or KEY_HELD
end

--[[
   name_function: function, the name itself, must return string ID defined in XML files for your option.
    if set to return nil, the option won't appear
--]]
function name_blockmove(obj)
    if not ENABLE then return nil end

    if is_blocked(obj:section()) then
        return gc("st_move_all_unblock")
    else
        return gc("st_move_all_block")
    end
end


--[[ 
    cond_action: function, the condition at which
        the action will be performed, usually its the same as name_condition_function
        you can put nil into argument to use the same function as name_condition_function
---]]	
function moveblock_menu_action(obj)
    sec = obj:section()
    set_blocked(sec, not blocked_items[sec])
end



override_bags = false

--#endregion

--#region Quick Release (qrs)
--[[
Shamelessly Stolen from Toxox's Mini Mods Repo
Go download it
--]]

orig_keep_items = nil

keep_items_script = nil
if actor_stash_patch then
	keep_items_script = actor_stash_patch
else
	keep_items_script = item_backpack
end


local curr_b = nil
local b_id = nil
orig_item_backpack_actor_on_item_use = item_backpack.actor_on_item_use
item_backpack.actor_on_item_use = function(obj)
	-- Check if we should keep favs
	if (not obj) or (obj:section() ~= "itm_actor_backpack")  then
		orig_item_backpack_actor_on_item_use(obj)
		return
	end

	-- Insert original keep items once
	if not orig_keep_items then
		orig_keep_items = {}
		copy_table(orig_keep_items, keep_items_script.keep_items)
	end

	-- Assign original keep items
	keep_items_script.keep_items = dup_table(orig_keep_items)

    -- local new_blocked_items = merge_tables({cfg_blocked_items, blocked_items}) or blocked_items

	-- Add current favorites
    debug("BLocked items")
    print_table(blocked_items)
    if  QUICKSTASH_BLOCKED_ITEMS then
        for k, _ in pairs(blocked_items) do
            debug("k = " .. tostring(k))
            debug("v = " .. tostring(_))
            keep_items_script.keep_items[k] = true
        end
        debug("keep items")
        print_table(keep_items_script.keep_items)
    end

    -- just added my own "Keep Favorites" right here, save a mod in my load order
    if  QUICKSTASH_FAVORITES or not zzz_rax_sortingplus_mcm then
        for k, _ in pairs(zzz_rax_sortingplus_mcm.favorite_itms) do
            debug("k = " .. tostring(k))
            debug("v = " .. tostring(_))
            keep_items_script.keep_items[k] = true
        end
    end

    orig_item_backpack_actor_on_item_use(obj)
end

