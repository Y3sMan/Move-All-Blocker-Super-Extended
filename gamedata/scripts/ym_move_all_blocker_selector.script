local VERSION = 1.0

-- mcm option to refresh config
-- always resets to false after closing mcm
local refresh_config = false
local reset_blocked_items = false

ENABLE = true
ENABLE_CONFIG = false -- enable use of permanent blacklist config file
-- whether to move blocked items into quick release stash
QUICKSTASH_BLOCKED_ITEMS = true  -- true will keep blacklisted items in your inventory on qrs
-- whether to move favorites into quick release stash
QUICKSTASH_FAVORITES = true  -- true will keep favorite items in your inventory on qrs

local mcm_keybinds = ui_mcm and ui_mcm.key_hold

-- key to hold to show the dynamic option
KEYBIND = DIK_keys.DIK_LCONTROL

-- temporarily toggle having to hold the KEYBIND to show the block option
-- true = always show
-- false = you have to hold KEYBIND
TOGGLE_KEYBIND = DIK_keys.DIK_R


-- key held state vars
KEY_HELD = false
TOGGLE_HELD = false

TOGGLE_HIDE = false  -- state control if block option is always shown or always hidden


blocked_items = {} -- items blacklisted in-game go here
cfg_blocked_items = {} -- items blacklisted via the config go here. Acts as cache

gc = game.translate_string


equipped_ammos = {} -- cache to keep track of all ammo for all equipped weapons
BLOCK_AMMO = true

--#region Table helpers

local function merge_tables(tables)
    local final_table = {}
    if #tables > 0 then
        copy_table(final_table, tables[1])
        if #tables > 1 then
            for i=2, #tables do
                for k,v in pairs(tables[i]) do
                    final_table[k] = v
                end
            end
        end
    end
    return final_table
end

-- Source - https://gist.github.com/sapphyrus/fd9aeb871e3ce966cc4b0b969f62f539?permalink_comment_id=4667958#gistcomment-4667958
--- deeply compare two objects and return the diff
function diff_tables(o1, o2)
	-- same object
	if o1 == o2 then return nil end

	local o1Type = type(o1)
	local o2Type = type(o2)
	--- different type
	if o1Type ~= o2Type then -- don't expand tables to make it more readable
		return { _1 = o1Type == 'table' and o1Type or o1, _2 = o2Type == 'table' and o2Type or o2 }
	end
	--- same type but not table, already compared above
	if o1Type ~= 'table' then return nil end

	local diff = {}

	-- iterate over o1
	for key1, value1 in pairs(o1) do
		local value2 = o2[key1]
		diff[key1] = diff_tables(value1, value2)
	end

	--- check keys in o2 but missing from o1
	for key2, value2 in pairs(o2) do
		diff[key2] = diff_tables(nil, value2)
	end
	local gen, param, state = pairs(diff)
	if gen(param, state) ~= nil then
		return diff
	else
		return nil
	end
end

