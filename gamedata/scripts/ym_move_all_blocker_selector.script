function load_settings()
end



function save_state(mdata)
    local t = {}
    t.blocked_items = blocked_items
    t.TOGGLE_HIDE = TOGGLE_HIDE or false
    t.cfg_cache = cfg_blocked_items
    t.equipped_ammos = equipped_ammos

    -- old v < 1.0
    -- t.QUICKSTASH_BLOCKED_ITEMS = QUICKSTASH_BLOCKED_ITEMS
    -- t.QUICKSTASH_FAVORITES = QUICKSTASH_FAVORITES
    -- t.ENABLE = ENABLE

    mdata.ym_move_all_blocker = t
end

function load_state(mdata)
    cleanup(mdata)

    local t = mdata.ym_move_all_blocker
    if t then
        blocked_items = t.blocked_items or {}
        local new_t = t.blocked_items or {}
        blocked_items = merge_tables({ blocked_items, new_t }) or blocked_items

        TOGGLE_HIDE = t.TOGGLE_HIDE or TOGGLE_HIDE

        cfg_blocked_items = t.cfg_cache or {}

        equipped_ammos = t.equipped_ammos or {}

        -- oldv < 1.0
        -- QUICKSTASH_BLOCKED_ITEMS = t.QUICKSTASH_BLOCKED_ITEMS or false
        -- QUICKSTASH_FAVORITES = t.QUICKSTASH_FAVORITES or false
    end
end

--#region Config stuff


---Remove unadded entries from config cache
---
---Then remove them from blocked_items
function cleanup_cfg_blocked_items()
	local ini_stash = ini_file("items\\settings\\ym_move_all_blocked_items.ltx")
    local new_cfg_blocked_items = utils_data.collect_section(ini_stash,"ym_blocked_items",true) or {}

    for k, v in pairs(cfg_blocked_items) do
        if (not new_cfg_blocked_items[k]) and (blocked_items[k]) then
            blocked_items[k] = nil
        end
    end
end


function refresh_config_file()

    -- cleanup removed entries from cfg cache
    cleanup_cfg_blocked_items()

    -- add new entries to cfg cache
	local ini_stash = ini_file("items\\settings\\ym_move_all_blocked_items.ltx")
    cfg_blocked_items = utils_data.collect_section(ini_stash,"ym_blocked_items",true) or {}

    -- combine with in-game table blocked_items
    blocked_items = merge_tables({cfg_blocked_items, blocked_items}) or blocked_items


    -- reset mcm refresh button
    refresh_config = false
    if ui_mcm then
        ui_mcm.set("blockputall_extended/refresh_config", refresh_config)
    end

    debug("blocked config:")
    print_table(blocked_items)
end


---Reset in-game-set blacklist.
---
---Does not affect items listed in config file
function do_reset_blocked_items()
    -- blocked_items = nil
    empty_table(blocked_items)
    blocked_items = blocked_items or {}

    -- reset mcm Reset button
    reset_blocked_items = false
    if ui_mcm then
        ui_mcm.set("blockputall_extended/reset_blocked_items", reset_blocked_items)
    end

    -- refresh config and cache
    refresh_config_file()
end


function on_option_change(mcm)
    if mcm then
		ENABLE	= ui_mcm.get("blockputall_extended/super_block_enable")
		QUICKSTASH_BLOCKED_ITEMS	= ui_mcm.get("blockputall_extended/QUICKSTASH_BLOCKED_ITEMS")
		QUICKSTASH_FAVORITES	= ui_mcm.get("blockputall_extended/QUICKSTASH_FAVORITES")
        refresh_config = ui_mcm.get("blockputall_extended/refresh_config")
        reset_blocked_items = ui_mcm.get("blockputall_extended/reset_blocked_items")
        TOGGLE_KEYBIND = ui_mcm.get("blockputall_extended/toggle_keybind")
        KEYBIND = ui_mcm.get("blockputall_extended/show_modifier")
        ENABLE_CONFIG =  ui_mcm.get("blockputall_extended/enable_config_file")
        BLOCK_AMMO =  ui_mcm.get("blockputall_extended/BLOCK_AMMO")
    end

    if refresh_config or ENABLE_CONFIG then
        refresh_config_file()
    end

    if reset_blocked_items then
        do_reset_blocked_items()
    end

    -- recheck blocked status for ammos
    block_equipped_ammos()
end

-- clean up save data
-- version to version
function cleanup(mdata)
    -- local mdata = alife_storage_manager.get_state() or {}
    local t = {}
    if mdata.ym_move_all_blocker then
        if VERSION > 0.5 then
            mdata.ym_move_all_blocker.QUICKSTASH_BLOCKED_ITEMS = nil
            mdata.ym_move_all_blocker.QUICKSTASH_FAVORITES = nil
            mdata.ym_move_all_blocker.ENABLE = nil
        end
    end
end

--#endregion


function on_game_start()
    if ENABLE_CONFIG then
        refresh_config_file()
    end
    debug("blocked config:")
    print_table(blocked_items)


    -- function add_functor(name, cond_name, func_name, cond_action, func_action, override_bags)
    custom_functor_autoinject.add_functor("ym_moveallblocker", can_be_blocked, name_blockmove, nil, moveblock_menu_action, true )

    RegisterScriptCallback("load_state", load_state)
    RegisterScriptCallback("save_state", save_state)
    RegisterScriptCallback("on_option_change", on_option_change)

    -- ammo management
    RegisterScriptCallback("actor_item_to_ruck", block_equipped_ammos)
    RegisterScriptCallback("actor_item_to_slot", block_equipped_ammos)
    RegisterScriptCallback("actor_on_item_drop", block_equipped_ammos)

    on_option_change(mcm_keybinds)
end


